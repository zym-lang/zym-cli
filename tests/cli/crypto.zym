// ============================================================================
// COMPREHENSIVE Crypto NATIVE TEST SUITE
// Exercises the `Crypto` global (statics: create / CryptoKey / X509Certificate)
// and the per-instance API on Crypto, CryptoKey, and X509Certificate handles
// (random bytes, RSA generation, self-signed certificates, sign / verify,
// encrypt / decrypt, HMAC digest, constant-time compare, key + cert PEM
// round-trips).
// ============================================================================

var testsPassed = 0
var testsFailed = 0

func assert_wrap(condition, message) {
    if (condition) {
        testsPassed = testsPassed + 1
    } else {
        testsFailed = testsFailed + 1
        print("FAILED: " + message)
    }
}

print("==========================================================")
print("Crypto NATIVE TEST SUITE")
print("==========================================================")


// ============================================================================
// SECTION 1: CONSTRUCTION
// ============================================================================
print("--- [1] Construction ---")

var c = Crypto.create()
assert_wrap(c != null, "1.1: Crypto.create returns a handle")
assert_wrap(c.generateRandomBytes != null, "1.2: handle exposes generateRandomBytes")
assert_wrap(c.generateRsa != null, "1.3: handle exposes generateRsa")
assert_wrap(c.sign != null, "1.4: handle exposes sign")
assert_wrap(c.verify != null, "1.5: handle exposes verify")
assert_wrap(c.encrypt != null, "1.6: handle exposes encrypt")
assert_wrap(c.decrypt != null, "1.7: handle exposes decrypt")
assert_wrap(c.hmacDigest != null, "1.8: handle exposes hmacDigest")
assert_wrap(c.constantTimeCompare != null, "1.9: handle exposes constantTimeCompare")

var k0 = Crypto.CryptoKey()
assert_wrap(k0 != null, "1.10: Crypto.CryptoKey returns an empty key handle")
assert_wrap(k0.isPublicOnly != null, "1.11: key handle exposes isPublicOnly")

var x0 = Crypto.X509Certificate()
assert_wrap(x0 != null, "1.12: Crypto.X509Certificate returns an empty cert handle")
assert_wrap(x0.saveToString != null, "1.13: cert handle exposes saveToString")


// ============================================================================
// SECTION 2: RANDOM BYTES
// ============================================================================
print("--- [2] generateRandomBytes ---")

var r0 = c.generateRandomBytes(0)
assert_wrap(r0 != null, "2.1: zero-length random buffer is non-null")
assert_wrap(r0.size() == 0, "2.2: zero-length random buffer has size 0")

var r1 = c.generateRandomBytes(16)
assert_wrap(r1.size() == 16, "2.3: 16-byte random buffer has correct size")

var r2 = c.generateRandomBytes(32)
assert_wrap(r2.size() == 32, "2.4: 32-byte random buffer has correct size")

// Probabilistic: two large random draws are extremely unlikely to be equal.
var r3 = c.generateRandomBytes(32)
assert_wrap(c.constantTimeCompare(r2, r3) == false, "2.5: distinct random draws differ")


// ============================================================================
// SECTION 3: RSA KEY GENERATION + PEM ROUND-TRIP
// ============================================================================
print("--- [3] generateRsa + PEM round-trip ---")

// 1024-bit RSA is fastest; we just need a working key for the rest of the
// suite, not crypto-grade strength.
var rsa = c.generateRsa(1024)
assert_wrap(rsa != null, "3.1: generateRsa(1024) returns a key")
assert_wrap(rsa.isPublicOnly() == false, "3.2: generated key has private material")

var privPem = rsa.saveToString(false)
assert_wrap(privPem != null, "3.3: saveToString(private) returns a string")
// PEM private keys begin with `-----BEGIN`.
assert_wrap(privPem != "", "3.4: private PEM is not empty")

var pubPem = rsa.saveToString(true)
assert_wrap(pubPem != null, "3.5: saveToString(public) returns a string")
assert_wrap(pubPem != privPem, "3.6: public PEM differs from private PEM")

// loadFromString: round-trip the private PEM into a fresh handle.
var rsa2 = Crypto.CryptoKey()
assert_wrap(rsa2.loadFromString(privPem, false) == true,
            "3.7: loadFromString(private) succeeds")
assert_wrap(rsa2.isPublicOnly() == false, "3.8: loaded key still private")

// Re-saving the loaded key produces the same PEM.
assert_wrap(rsa2.saveToString(false) == privPem,
            "3.9: re-saved private PEM round-trips identically")

// Public-only round-trip.
var rsaPub = Crypto.CryptoKey()
assert_wrap(rsaPub.loadFromString(pubPem, true) == true,
            "3.10: loadFromString(public, publicOnly=true) succeeds")
assert_wrap(rsaPub.isPublicOnly() == true,
            "3.11: public-only key reports isPublicOnly=true")

// Bad PEM: returns false.
var bad = Crypto.CryptoKey()
assert_wrap(bad.loadFromString("not a pem", false) == false,
            "3.12: loadFromString rejects garbage input")


// ============================================================================
// SECTION 4: SELF-SIGNED X509 CERTIFICATE
// ============================================================================
print("--- [4] generateSelfSignedCertificate ---")

var cert = c.generateSelfSignedCertificate(
    rsa, "CN=zym test", "20230101000000", "20330101000000")
assert_wrap(cert != null, "4.1: generateSelfSignedCertificate returns a handle")

var certPem = cert.saveToString()
assert_wrap(certPem != null, "4.2: cert.saveToString returns a string")
assert_wrap(certPem != "", "4.3: cert PEM is not empty")

// PEM round-trip.
var cert2 = Crypto.X509Certificate()
assert_wrap(cert2.loadFromString(certPem) == true,
            "4.4: cert loadFromString round-trips")
assert_wrap(cert2.saveToString() == certPem,
            "4.5: re-saved cert PEM round-trips identically")

// Bad PEM rejected.
var badCert = Crypto.X509Certificate()
assert_wrap(badCert.loadFromString("not a cert") == false,
            "4.6: cert loadFromString rejects garbage input")


// ============================================================================
// SECTION 5: SIGN / VERIFY
// ============================================================================
// `Crypto.sign(hashType, hash, key)` expects `hash` to be a precomputed
// digest of the message (32 bytes for sha256, 20 for sha1, 16 for md5),
// not the raw message. We use `hmacDigest` to derive a deterministic
// 32-byte digest from a known message + key.
print("--- [5] sign / verify ---")

var sigKey = Buffer.fromString("test-hmac-key")
var hash256 = c.hmacDigest("sha256", sigKey, Buffer.fromString("hello world"))
assert_wrap(hash256.size() == 32, "5.0: precomputed sha256 hash is 32 bytes")

var sig = c.sign("sha256", hash256, rsa)
assert_wrap(sig != null, "5.1: sign returns a signature buffer")
assert_wrap(sig.size() > 0, "5.2: signature is non-empty")

assert_wrap(c.verify("sha256", hash256, sig, rsa) == true,
            "5.3: verify accepts genuine (hash, sig)")

// Tampered hash must not verify.
var tamperedHash = c.hmacDigest("sha256", sigKey, Buffer.fromString("HELLO WORLD"))
assert_wrap(c.verify("sha256", tamperedHash, sig, rsa) == false,
            "5.4: verify rejects tampered hash")

// Verify with public-only key works (public key is enough to verify).
assert_wrap(c.verify("sha256", hash256, sig, rsaPub) == true,
            "5.5: verify works against public-only key")

// SHA1 sign/verify round-trip.
var hash1 = c.hmacDigest("sha1", sigKey, Buffer.fromString("hello world"))
assert_wrap(hash1.size() == 20, "5.6: precomputed sha1 hash is 20 bytes")
var sig1 = c.sign("sha1", hash1, rsa)
assert_wrap(sig1 != null, "5.7: sign(sha1) returns a signature")
assert_wrap(c.verify("sha1", hash1, sig1, rsa) == true,
            "5.8: verify(sha1) accepts genuine sha1 signature")


// ============================================================================
// SECTION 6: ENCRYPT / DECRYPT (RSA OAEP via Godot Crypto.encrypt/decrypt)
// ============================================================================
print("--- [6] encrypt / decrypt ---")

var pt = Buffer.fromString("secret payload")
var ct = c.encrypt(rsaPub, pt)
assert_wrap(ct != null, "6.1: encrypt returns a ciphertext buffer")
assert_wrap(ct.size() > 0, "6.2: ciphertext is non-empty")
// RSA-encrypted output should not equal the plaintext.
assert_wrap(c.constantTimeCompare(ct, pt) == false,
            "6.3: ciphertext differs from plaintext")

var pt2 = c.decrypt(rsa, ct)
assert_wrap(pt2 != null, "6.4: decrypt returns a plaintext buffer")
assert_wrap(c.constantTimeCompare(pt2, pt) == true,
            "6.5: decrypt(encrypt(pt)) round-trips")

// Two encryptions of the same plaintext produce different ciphertexts (OAEP
// uses a fresh random seed each call).
var ct2 = c.encrypt(rsaPub, pt)
assert_wrap(c.constantTimeCompare(ct, ct2) == false,
            "6.6: RSA OAEP encryption is randomized")


// ============================================================================
// SECTION 7: HMAC DIGEST
// ============================================================================
print("--- [7] hmacDigest ---")

var hmKey = Buffer.fromString("hmac-key")
var hmMsg = Buffer.fromString("hello world")

var d256 = c.hmacDigest("sha256", hmKey, hmMsg)
assert_wrap(d256 != null, "7.1: hmacDigest(sha256) returns a buffer")
assert_wrap(d256.size() == 32, "7.2: sha256 digest is 32 bytes")

var d256b = c.hmacDigest("sha256", hmKey, hmMsg)
assert_wrap(c.constantTimeCompare(d256, d256b) == true,
            "7.3: hmacDigest is deterministic for the same inputs")

// Different key -> different digest.
var d256c = c.hmacDigest("sha256", Buffer.fromString("other-key"), hmMsg)
assert_wrap(c.constantTimeCompare(d256, d256c) == false,
            "7.4: digest changes with key")

// Different message -> different digest.
var d256d = c.hmacDigest("sha256", hmKey, Buffer.fromString("HELLO WORLD"))
assert_wrap(c.constantTimeCompare(d256, d256d) == false,
            "7.5: digest changes with message")

// SHA1 digest is 20 bytes.
var d1 = c.hmacDigest("sha1", hmKey, hmMsg)
assert_wrap(d1.size() == 20, "7.6: sha1 hmac digest is 20 bytes")

// Note: Godot's HMACContext only supports sha1 and sha256 (md5 hits
// `"Unsupported hash type."`), so we don't exercise md5 here.

// Hash-type lookup is case-insensitive.
var d256upper = c.hmacDigest("SHA256", hmKey, hmMsg)
assert_wrap(c.constantTimeCompare(d256, d256upper) == true,
            "7.7: hash type is case-insensitive")


// ============================================================================
// SECTION 8: constantTimeCompare
// ============================================================================
print("--- [8] constantTimeCompare ---")

var a = Buffer.fromString("abcdef")
var b = Buffer.fromString("abcdef")
var dDif = Buffer.fromString("abcdeg")
var shorter = Buffer.fromString("abcde")

assert_wrap(c.constantTimeCompare(a, b) == true,
            "8.1: equal buffers compare true")
assert_wrap(c.constantTimeCompare(a, dDif) == false,
            "8.2: same-length differing buffers compare false")
assert_wrap(c.constantTimeCompare(a, shorter) == false,
            "8.3: different-length buffers compare false")


// ============================================================================
// SECTION 9: KEY ALIASING + RECOMPILE-LIKE BEHAVIOR
// ============================================================================
print("--- [9] CryptoKey aliasing ---")

// Plain assignment aliases the underlying handle. loadFromString through one
// alias is visible through the other.
var aliasA = Crypto.CryptoKey()
var aliasB = aliasA
assert_wrap(aliasA.isPublicOnly() == aliasB.isPublicOnly(),
            "9.1: aliases share initial state")

aliasB.loadFromString(privPem, false)
assert_wrap(aliasA.isPublicOnly() == false,
            "9.2: load through alias is visible on source")

// Loading a separate public-only key handle is exercised in section 3;
// here we only need to confirm aliasing works for the private case.


// ============================================================================
// FINAL: REPORT
// ============================================================================
print("==========================================================")
print("Tests Passed:")
print(testsPassed)
print("Tests Failed:")
print(testsFailed)
if (testsFailed == 0) {
    print("ALL TESTS PASSED!")
}
print("==========================================================")
